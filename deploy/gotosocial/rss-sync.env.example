# Required
GTS_BASE_URL=https://social.fft.im
GTS_ACCESS_TOKEN=replace-with-a-write-scoped-token

# Default: sync notes feed
RSS_SYNC_FEED_URL=https://fft.im/notes/rss.xml

# Optional behavior
RSS_SYNC_PREFIX=New note:
RSS_SYNC_VISIBILITY=public
RSS_SYNC_INCLUDE_DESCRIPTION=false
RSS_SYNC_MAX_POSTS=3
RSS_SYNC_LANGUAGE=zh

# On first run, existing items are marked as seen without posting.
# Set this to true only if you explicitly want to post historical notes.
RSS_SYNC_BACKFILL=false

# Paths
RSS_SYNC_STATE_FILE=/opt/gotosocial/rss-sync-state.json
