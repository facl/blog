---
import type { PaginationLink } from "@/types";
import { normalizePathname } from "@/utils/url";

interface Props {
	nextUrl?: PaginationLink;
	prevUrl?: PaginationLink;
}

const { nextUrl, prevUrl } = Astro.props;

const withNormalizedUrl = (link?: PaginationLink) =>
	link
		? {
				...link,
				url: normalizePathname(link.url),
			}
		: undefined;

const normalizedPrevUrl = withNormalizedUrl(prevUrl);
const normalizedNextUrl = withNormalizedUrl(nextUrl);
---

{
	(normalizedPrevUrl || normalizedNextUrl) && (
		<nav class="mt-8 flex items-center gap-x-4">
			{normalizedPrevUrl && (
				<a
					class="me-auto py-2 font-display text-xs uppercase tracking-[0.2em] text-accent underline-offset-4 transition-all duration-300 hover:underline hover:tracking-[0.25em]"
					data-astro-prefetch
					href={normalizedPrevUrl.url}
				>
					{normalizedPrevUrl.srLabel && <span class="sr-only">{normalizedPrevUrl.srLabel}</span>}
					← {normalizedPrevUrl.text ? normalizedPrevUrl.text : "Previous"}
				</a>
			)}
			{normalizedNextUrl && (
				<a
					class="ms-auto py-2 font-display text-xs uppercase tracking-[0.2em] text-accent underline-offset-4 transition-all duration-300 hover:underline hover:tracking-[0.25em]"
					data-astro-prefetch
					href={normalizedNextUrl.url}
				>
					{normalizedNextUrl.srLabel && <span class="sr-only">{normalizedNextUrl.srLabel}</span>}
					{normalizedNextUrl.text ? normalizedNextUrl.text : "Next"} →
				</a>
			)}
		</nav>
	)
}
