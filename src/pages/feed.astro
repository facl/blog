---
import PageLayout from "@/layouts/Base.astro";

const meta = {
	description: "RSS 订阅",
	title: "订阅",
};
---

<PageLayout meta={meta}>
	<div class="mx-auto max-w-4xl w-full">
		<header class="mb-12">
			<div class="mb-8 flex items-center gap-4">
				<span class="ornate-divider flex-1"></span>
				<span class="font-display text-sm font-medium uppercase tracking-[0.25em] text-accent engraved">
					订阅
				</span>
				<span class="ornate-divider flex-1"></span>
			</div>
		</header>

		<section class="mb-12 border border-border bg-bgAlt/30 p-6 sm:p-8">
			<p class="font-body text-base leading-relaxed text-textColor">
				信息流太吵，算法太蠢。RSS 是一种拒绝被推荐引擎喂养的阅读方式，它只负责同步，没有点赞，没有停留时长统计，没有猜你喜欢。
			</p>
			<p class="font-body text-base leading-relaxed text-textColor mt-4">
				长文和笔记分两个源。
			</p>
			<div class="mt-6 flex flex-wrap gap-3">
				<a
					href="/rss.xml"
					class="inline-flex items-center gap-2 rounded bg-bgColor px-4 py-2 font-mono text-sm text-accent transition-colors hover:bg-accent/10"
				>
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
					https://fft.im/rss.xml
				</a>
				<a
					href="/notes/rss.xml"
					class="inline-flex items-center gap-2 rounded bg-bgColor px-4 py-2 font-mono text-sm text-accent transition-colors hover:bg-accent/10"
				>
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
					https://fft.im/notes/rss.xml
				</a>
			</div>
		</section>
	</div>
</PageLayout>
